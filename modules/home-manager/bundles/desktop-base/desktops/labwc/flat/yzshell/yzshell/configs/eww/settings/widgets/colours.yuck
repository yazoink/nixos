(defvar colourschemes "[]")

(defwidget colourschemes []
  (scroll
    :hscroll false
    :vscroll true
    :class "colours-scroller"
    (box
      :class "colours-box"
      :orientation "v"
      :space-evenly false
      :spacing 8
      (for scheme in colourschemes
        (button
          :onclick "${get_env("YZSHELL_CMD")} 'colourscheme' '${scheme["id"]}' &"
          :class "scheme-button"
          :tooltip "Apply colourscheme"
          :style "background-color: #${scheme["base00"]}; border: 1px solid #${scheme["base01"]};"
          (box
            :orientation "v"
            :class "scheme-box"
            :space-evenly false
            :spacing 8
            (label
              :text "${scheme["scheme"]}" 
              :class "scheme-name"
              :halign "start" 
              :hexpand "true"
              :style "color: #${scheme["base05"]};"
            )
            (box
              :spacing 8
              :orientation "v"
              :class "scheme-colours"
              (box
                :spacing 8
                :orientation "h"
                (label :text "" :style "background-color: #${scheme["base08"]};")
                (label :text "" :style "background-color: #${scheme["base09"]};")
                (label :text "" :style "background-color: #${scheme["base0A"]};")
                (label :text "" :style "background-color: #${scheme["base0B"]};")
                (label :text "" :style "background-color: #${scheme["base0C"]};")
                (label :text "" :style "background-color: #${scheme["base0D"]};")
                (label :text "" :style "background-color: #${scheme["base0E"]};")
                (label :text "" :style "background-color: #${scheme["base0F"]};")
              )
            )
          )
        )
      )
    )
  )
)
