(defvar calendar_visible false)

(include "./widgets/clock.yuck")

(defwindow calendar
  :monitor 0
  :geometry (geometry
    :x 4
    :y 4
    :anchor "bottom right"
  )
  :stacking "fg"
  :exclusive false
  :focusable "ondemand"
  (revealer
    :transition "slideup"
    :reveal calendar_visible
    (box
      :orientation "vertical"
      :space-evenly false
      :class "calendar-box"
      :spacing 8
      :halign "fill"
      (calendar_clock)
      (box :class "calendar" :orientation "v"
        (calendar :class "cal" :halign "center")
      )
    )
  )
)
