(defpoll username :run-while control_panel_visible :initial "" :interval "24h" `whoami`)
(defpoll hostname :run-while control_panel_visible :initial "" :interval "24h" `hostname`)
(defpoll os-version :run-while control_panel_visible :initial "idk" :interval "24h" "${get_env("YZSHELL_CMD")} get os_version")

(defwidget user []
  (box
    :class "user-box"
    :orientation "horizontal"
    :valign "start"
    :spacing 8
    :space-evenly false
    :halign "fill"
    :hexpand true
    (box
      :class "profile-image"
      :vexpand false 
      :hexpand false 
      :style "background-image: url('${get_env("PROFILE_IMAGE")}');"
    )
    (box
      :class "username-hostname-os"
      :orientation "vertical"
      :space-evenly false
      :valign "center"
      (box
        :class "username-hostname"
        :halign "start"
        :hexpand true
        :space-evenly false
        :orientation "horizontal"
        (label :text "${username}" :class "username" :halign "start")
        (label :text "@" :class "at")
        (label :text "${hostname}" :class "hostname")
      )
      (label :text "${os-version}" :class "os-version" :halign "start")
    )
    (button 
      :class "reveal-button" 
      :halign "end"
      :hexpand true 
      :onclick {menu_visible ? "${EWW_CMD} update menu_visible=false" : "${EWW_CMD} update menu_visible=true"}
      {menu_visible ? "" : ""})
  )
)
